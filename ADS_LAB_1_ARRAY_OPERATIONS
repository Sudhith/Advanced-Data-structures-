#include <stdio.h>
void readArray(int arr[], int n);
void printArray(int [], int);
void insert(int [], int, int, int);
void searchArray(int [], int, int);
void deleteArr(int [], int, int);

int main()
{
    int n, size, choice, pos, target, a;

    printf("Enter the max number of elements (size) in the array: ");
    scanf("%d", &size);

    int arr[size];

    printf("Enter number of elements you want to add: ");
    scanf("%d", &n);

    while(1)
    {
        printf("1. Read/Declare an array\n 2. Print the array \n 3. Insert an Element \n 4. Delete an element \n 5. Search an element \n 6. Exit");
        printf("\n Enter your choice: \n ");
        scanf("%d", &choice);
        switch(choice)
        {
            case 1:
                readArray(arr, n);
                break;

            case 2:
                printArray(arr, n);
                break;

            case 3:
                printf("Enter the position you want to insert: ");
                scanf("%d", &pos);
                printf("Enter the element you want to insert: ");
                scanf("%d", &a);
                if (pos >= 0 && pos <= n)
                {
                    insert(arr, n, pos, a);
                    n++;
                }
                else
                {
                    printf("Invalid Position\n");
                }
                break;

            case 4:
                printf("Enter the position you want to delete: ");
                scanf("%d", &pos);
                if (pos >= 0 && pos < n)
                {
                    deleteArr(arr, n, pos);
                    n--;
                }
                else
                {
                    printf("Invalid Position\n");
                }
                break;

            case 5:
                printf("Enter the element you want to search: ");
                scanf("%d", &target);
                searchArray(arr, n, target);
                break;

            case 6:
                printf("Exiting\n");
                return 1;

            default:
                printf("Invalid Choice\n");
        }
    }

    return 0;
}

void readArray(int arr[], int n)
{
    for(int i = 0; i < n; i++)
    {
        printf("Enter element %d: ", i + 1);
        scanf("%d", &arr[i]);
    }
    printf("Array reading is successful\n");
}

void printArray(int arr[], int n)
{
    printf("Array: ");

    for(int i = 0; i < n; i++)
    {
        printf("%d ", arr[i]);
    }
}

void insert(int arr[], int n, int pos, int a)
{
    for(int i = n; i > pos; i--)
    {
        arr[i] = arr[i - 1];
    }
    arr[pos] = a;
    printf("Array after inserting:\n");
    printArray(arr, n + 1);
}

void searchArray(int arr[], int n, int target)
{
    int found = 0;
    for(int i = 0; i < n; i++)
    {
        if(arr[i] == target)
        {
            printf("Element found at position %d\n", i);
            found = 1;
            break;
        }
    }
    if(!found)
    {
        printf("Element not found \n");
    }
}

void deleteArr(int arr[], int n, int pos)
{
    for(int i = pos; i < n - 1; i++)
    {
        arr[i] = arr[i + 1];
    }
    printf("Array after deleting:\n");
    printArray(arr, n - 1);
}
